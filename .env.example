# Crisis-Cost Orchestrator — Environment Variables
# Copy this file to .env and fill in values

# ── Application ──────────────────────────────────────────────────────────────
COCO_DEBUG=true
COCO_APP_NAME="Crisis-Cost Orchestrator"

# ── Audit Ledger ─────────────────────────────────────────────────────────────
COCO_AUDIT_ENABLED=true

# ── PostgreSQL (for audit projection) ────────────────────────────────────────
COCO_DB_HOST=localhost
COCO_DB_PORT=5432
COCO_DB_NAME=crisiscost
COCO_DB_USER=coco
COCO_DB_PASSWORD=changeme

# ── Redis (for caching) ─────────────────────────────────────────────────────
COCO_REDIS_URL=redis://localhost:6379/0

# ── Temporal (for workflow orchestration) ────────────────────────────────────
COCO_TEMPORAL_HOST=localhost
COCO_TEMPORAL_PORT=7233
COCO_TEMPORAL_NAMESPACE=default

# ── Payment Rails ────────────────────────────────────────────────────────────
COCO_ACH_API_KEY=your-ach-api-key
COCO_WIRE_API_KEY=your-wire-api-key
COCO_STABLECOIN_API_KEY=your-stablecoin-api-key
